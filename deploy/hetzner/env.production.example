# /var/www/vidinsecs/server/.env — VidInSecs production

NODE_ENV=production
PORT=3000
CLIENT_ORIGIN=https://vidinsecs.com,https://www.vidinsecs.com

# Rate limits (Express — Nginx also limits /api to 10 req/s)
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100
DOWNLOAD_RATE_LIMIT_MAX=10

# Temp downloads (deleted after R2 upload)
TEMP_DOWNLOAD_DIR=/tmp/vidinsecs

# Skip R2 — serve downloads directly from VPS (set this while R2 is not ready)
SKIP_R2=1

# Cloudflare R2 (S3-compatible) — uncomment and fill when ready; set SKIP_R2=0
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY=your_r2_access_key_id
# R2_SECRET_KEY=your_r2_secret_access_key
# R2_BUCKET_NAME=vidinsecs-downloads
# R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
# R2_PUBLIC_URL=https://downloads.vidinsecs.com
# R2_PRESIGN_EXPIRY=3600

# RapidAPI fallback (optional)
RAPIDAPI_KEY=
RAPIDAPI_HOST=yt-api.p.rapidapi.com
RAPIDAPI_INSTAGRAM_HOST=instagram-downloader.p.rapidapi.com
RAPIDAPI_TIKTOK_HOST=tiktok-download-video1.p.rapidapi.com

# FFmpeg path on Ubuntu
FFMPEG_PATH=/usr/bin/ffmpeg

# Deploy script — Cloudflare cache purge (optional)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ZONE_ID=