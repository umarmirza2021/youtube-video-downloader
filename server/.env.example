PORT=3000
CLIENT_ORIGIN=http://localhost:5173

# Rate limits
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100
DOWNLOAD_RATE_LIMIT_MAX=10

# Skip R2 and stream downloads directly from server (local dev default)
SKIP_R2=1

# Cloudflare R2 (production — upload to R2 then return link; set SKIP_R2=0)
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY=
# R2_SECRET_KEY=
# R2_BUCKET_NAME=vidinsecs-downloads
# R2_ENDPOINT=
# R2_PUBLIC_URL=
# R2_PRESIGN_EXPIRY=3600
TEMP_DOWNLOAD_DIR=

# RapidAPI fallback (optional)
RAPIDAPI_KEY=your_rapidapi_key_here
RAPIDAPI_HOST=yt-api.p.rapidapi.com
RAPIDAPI_INSTAGRAM_HOST=instagram-downloader.p.rapidapi.com
RAPIDAPI_TIKTOK_HOST=tiktok-download-video1.p.rapidapi.com

FFMPEG_PATH=/usr/bin/ffmpeg